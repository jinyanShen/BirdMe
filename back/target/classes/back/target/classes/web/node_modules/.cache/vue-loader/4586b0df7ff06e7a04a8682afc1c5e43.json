{"remainingRequest":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\code\\BirdME\\web\\src\\views\\identification\\index.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\code\\BirdME\\web\\src\\views\\identification\\index.vue","mtime":1741255476237},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\babel-loader\\lib\\index.js","mtime":1773241107115},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js","mtime":1773241108107}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;AA4BA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/identification","sourcesContent":["<template>\r\n    <div class=\"container\">\r\n      <!-- 第一部分：上传按钮 -->\r\n      <div class=\"section\">\r\n        <input type=\"file\" @change=\"handleImageUpload\" accept=\"image/*\">\r\n      </div>\r\n  \r\n      <!-- 第二部分：图片展示 -->\r\n      <div class=\"section\">\r\n        <img v-if=\"imageSrc\" style=\"width: 400px; height: 200px;\" :src=\"imageSrc\" alt=\"Uploaded Image\">\r\n        <p v-else>请上传图片</p>\r\n      </div>\r\n  \r\n      <!-- 第三部分：物种名称 -->\r\n      <div class=\"section\">\r\n        <h1 v-if=\"form.name\">{{ form.name }}</h1>\r\n        <h1 v-else>物种名称</h1>\r\n      </div>\r\n  \r\n      <!-- 第四部分：物种介绍 -->\r\n      <div class=\"section\">\r\n        <p v-if=\"form.description\">{{ form.description }}</p>\r\n        <p v-else>物种介绍</p>\r\n      </div>\r\n    </div>\r\n  </template>\r\n  \r\n  <script>\r\n  export default {\r\n    data() {\r\n      return {\r\n        imageSrc: '',\r\n        form: {}\r\n      }\r\n    },\r\n    methods: {\r\n      handleImageUpload(event) {\r\n        const file = event.target.files[0];\r\n        if (file) {\r\n          const reader = new FileReader();\r\n          reader.onloadend = () => {\r\n            this.imageSrc = reader.result;\r\n          };\r\n          reader.readAsDataURL(file);\r\n\r\n          const formData = new FormData();\r\n          formData.append('file', file); \r\n          fetch('http://localhost:8080/file/identification', {\r\n            method: 'POST',\r\n            body: formData,\r\n          })\r\n          .then(response => response.json())\r\n          .then(data => {\r\n            if(data.code === 200){\r\n              this.form = data.data\r\n            }else{\r\n              this.$message.error(data.msg);\r\n            }\r\n          })\r\n          .catch(error => {\r\n            this.$message.error(\"识别失败\");\r\n          });\r\n        }else{\r\n          this.$message.error(\"请上传图片\");\r\n        }\r\n      }\r\n    }\r\n  }\r\n  </script>\r\n  \r\n  <style>\r\n  .container {\r\n    display: flex;\r\n    flex-direction: column;\r\n    height: 100vh;\r\n    justify-content: center;\r\n    align-items: center;\r\n  }\r\n  \r\n  .section {\r\n    width: 80%;\r\n    max-width: 600px;\r\n    text-align: center;\r\n    margin: 10px 0;\r\n    border: 1px solid #ddd;\r\n    border-radius: 8px;\r\n    padding: 10px;\r\n    box-sizing: border-box;\r\n  }\r\n  \r\n  img {\r\n    max-width: 100%;\r\n    height: auto;\r\n    margin: 20px 0;\r\n  }\r\n  \r\n  h1 {\r\n    color: #2c3e50;\r\n    font-size: 24px;\r\n  }\r\n  \r\n  p {\r\n    color: #666;\r\n    line-height: 1.6;\r\n  }\r\n  </style>"]}]}