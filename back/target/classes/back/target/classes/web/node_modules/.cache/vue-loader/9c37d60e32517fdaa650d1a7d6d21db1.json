{"remainingRequest":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\code\\BirdME\\web\\src\\views\\user\\index.vue?vue&type=script&lang=js","dependencies":[{"path":"D:\\code\\BirdME\\web\\src\\views\\user\\index.vue","mtime":1742631784396},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\babel-loader\\lib\\index.js","mtime":1773241107115},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js","mtime":1773241108107}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsLA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/user","sourcesContent":["<template>\r\n  <div class=\"app-container\">\r\n    <el-row>\r\n      <!--用户数据-->\r\n      <el-col :span=\"24\">\r\n        <el-form :model=\"queryParams\" ref=\"queryForm\" :inline=\"true\" label-width=\"68px\">\r\n          <el-form-item>\r\n            <el-button type=\"primary\" @click=\"handleAdd\">添加用户</el-button>\r\n          </el-form-item>\r\n          <el-form-item prop=\"name\" style=\"margin-left: 660px;\">\r\n            <el-input\r\n              v-model=\"queryParams.data.name\"\r\n              placeholder=\"根据用户真实姓名查询\"\r\n              clearable\r\n              style=\"width: 180px;\"\r\n              class=\"custom-height-input\"\r\n              @keyup.enter.native=\"handleQuery\"\r\n            />\r\n          </el-form-item>\r\n          <el-form-item>\r\n            <el-button type=\"primary\" icon=\"el-icon-search\" @click=\"handleQuery\"></el-button>\r\n            <el-button icon=\"el-icon-refresh-right\" type=\"primary\" @click=\"resetQuery\">重置</el-button>\r\n          </el-form-item>\r\n        </el-form>\r\n\r\n        <el-table border v-loading=\"loading\" :data=\"userList\" :header-cell-style=\"{ background: '#ffffff', color: '#333' }\">\r\n          <el-table-column label=\"用户id\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.id }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户名\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.username }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户密码\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.password }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户角色\">\r\n            <template slot-scope=\"scope\">\r\n              <span v-if=\"scope.row.role === 0\">普通用户</span>\r\n              <span v-if=\"scope.row.role === 1\">管理员</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户真实姓名\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.name }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户年龄\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.age }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户手机号码\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.phone }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"用户头像url\">\r\n            <template slot-scope=\"scope\">\r\n              <img :src=\"scope.row.avatarUrl\" style=\"width:100px;height:100px\">\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column label=\"创建时间\">\r\n            <template slot-scope=\"scope\">\r\n              <span >{{ scope.row.createdAt }}</span>\r\n            </template>\r\n          </el-table-column>\r\n          <el-table-column\r\n            label=\"操作\"\r\n          >\r\n            <template slot-scope=\"scope\">\r\n              <el-button\r\n              size=\"mini\"\r\n                @click=\"handleUpdate(scope.row)\"\r\n              >编辑</el-button>\r\n              <el-button\r\n              size=\"mini\"\r\n                type=\"danger\"\r\n                @click=\"handleDelete(scope.row)\"\r\n              >删除</el-button>\r\n            </template>\r\n          </el-table-column>\r\n        </el-table>\r\n\r\n        <pagination\r\n          v-show=\"totalCount>0\"\r\n          :total=\"totalCount\"\r\n          :page.sync=\"queryParams.offset\"\r\n          :limit.sync=\"queryParams.pageSize\"\r\n          @pagination=\"getList\"\r\n        />\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <!-- 添加或修改参数配置对话框 -->\r\n    <el-dialog :title=\"title\" :visible.sync=\"open\" width=\"600px\" append-to-body>\r\n      <el-form ref=\"form\" :model=\"form\" :rules=\"rules\" label-width=\"120px\">\r\n        <el-row>\r\n          <el-form-item label=\"用户名\">\r\n            <el-input v-model=\"form.username\" placeholder=\"请输入用户名\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户密码\">\r\n            <el-input v-model=\"form.password\" placeholder=\"请输入用户密码\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户角色\">\r\n            <el-select\r\n                    v-model=\"form.role\"\r\n                    placeholder=\"选择用户角色\"\r\n                    clearable\r\n                    size=\"small\"\r\n                    style=\"width: 200px\"\r\n                    @change=\"handleQuery\"\r\n            >\r\n                <el-option label=\"普通用户\" value=\"0\"/>\r\n                <el-option label=\"管理员\" value=\"1\"/>\r\n            </el-select>\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户真实姓名\">\r\n            <el-input v-model=\"form.name\" placeholder=\"请输入用户真实姓名\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户年龄\">\r\n            <el-input v-model=\"form.age\" placeholder=\"请输入用户年龄\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户手机号码\">\r\n            <el-input v-model=\"form.phone\" placeholder=\"请输入用户手机号码\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户头像\" prop=\"avatarUrl\">\r\n            <el-upload\r\n              drag\r\n              action=\"http://localhost:8080/file/upload\"\r\n              :on-success=\"handleUploadSuccess\"\r\n              :on-error=\"handleUploadError\"\r\n              list-type=\"picture\"\r\n              :limit=\"1\"\r\n              :show-file-list=\"false\"\r\n              :file-list=\"pictureList\"\r\n              :on-exceed=\"handleExceed\"\r\n              accept=\".png, .jpg, .jpeg\"\r\n            >\r\n              <i class=\"el-icon-upload\"></i>\r\n              <div class=\"el-upload__text\">拖拽文件到此处上传</div>\r\n            </el-upload>\r\n            <!-- 自定义图片和删除按钮 -->\r\n            <div v-if=\"form.avatarUrl\" class=\"image-preview\">\r\n              <img :src=\"form.avatarUrl\" alt=\"用户头像\" style=\"width: 100px; height: 100px;\" />\r\n              <el-button\r\n                type=\"danger\"\r\n                size=\"mini\"\r\n                icon=\"el-icon-delete\"\r\n                @click=\"handleRemoveImage\"\r\n                style=\"margin-left: 10px;\"\r\n              ></el-button>\r\n            </div>\r\n          </el-form-item>\r\n        </el-row>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button type=\"primary\" @click=\"submitForm\">确 定</el-button>\r\n        <el-button @click=\"cancel\">取 消</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { pageUser, getUser, delUser, insertUser, updateUser } from \"@/api/user\";\r\n\r\nexport default {\r\n  name: \"User\",\r\n  data() {\r\n    return {\r\n      // 遮罩层\r\n      loading: true,\r\n      // 选中数组\r\n      ids: [],\r\n      // 非单个禁用\r\n      single: true,\r\n      // 非多个禁用\r\n      multiple: true,\r\n      // 总条数\r\n      totalCount: 0,\r\n      // 用户表格数据\r\n      userList: null,\r\n      // 弹出层标题\r\n      title: \"\",\r\n      // 是否显示弹出层\r\n      open: false,\r\n      // 表单参数\r\n      form: {},\r\n      // 查询参数\r\n      queryParams: {\r\n        offset: 1,\r\n        pageSize: 10,\r\n        data: {\r\n          name: '',\r\n        },\r\n      },\r\n      // 表单校验\r\n      rules: {\r\n        \r\n      },\r\n      pictureList: []\r\n    };\r\n  },\r\n  created() {\r\n    this.getList();\r\n  },\r\n  methods: {\r\n    /** 查询用户列表 */\r\n    getList() {\r\n      this.loading = true;\r\n      pageUser(this.queryParams).then(response => {\r\n          this.userList = response.data;\r\n          this.totalCount = response.totalCount;\r\n          this.loading = false;\r\n        }\r\n      );\r\n    },\r\n    // 取消按钮\r\n    cancel() {\r\n      this.open = false;\r\n      this.reset();\r\n    },\r\n    // 表单重置\r\n    reset() {\r\n      this.form = {\r\n        id: undefined,\r\n        username: undefined,\r\n        password: undefined,\r\n        role: undefined,\r\n        name: undefined,\r\n        age: undefined,\r\n        phone: undefined,\r\n        avatarUrl: undefined,\r\n        createdAt: undefined,\r\n      };\r\n      this.pictureList = []\r\n    },\r\n    /** 搜索按钮操作 */\r\n    handleQuery() {\r\n      this.queryParams.offset = 1;\r\n      this.getList();\r\n    },\r\n    /** 重置按钮操作 */\r\n    resetQuery() {\r\n      this.queryParams.data.name = '',\r\n      this.handleQuery();\r\n    },\r\n    /** 新增按钮操作 */\r\n    handleAdd() {\r\n      this.reset();\r\n      this.open = true;\r\n      this.title = \"添加用户\";\r\n    },\r\n    /** 修改按钮操作 */\r\n    handleUpdate(row) {\r\n      this.reset();\r\n      const id = row.id;\r\n      this.pictureList.push(row.avatarUrl)\r\n      getUser(id).then(response => {\r\n        this.form = response.data;\r\n        this.form.role = this.form.role === 0 ? '普通用户' : '管理员'\r\n        this.open = true;\r\n        this.title = \"修改用户\";\r\n        this.pictureList.push({\"url\":this.form.avatarUrl})\r\n      });\r\n    },\r\n    /** 提交按钮 */\r\n    submitForm: function() {\r\n      this.$refs[\"form\"].validate(valid => {\r\n        if (valid) {\r\n          if (this.form.id != undefined) {\r\n            this.form.role = this.form.role === '普通用户' ? 0 : 1\r\n            updateUser(this.form).then(response => {\r\n              this.$message.success(\"修改成功\");\r\n              this.open = false;\r\n              this.getList();\r\n            });\r\n          } else {\r\n            insertUser(this.form).then(response => {\r\n              this.$message.success(\"新增成功\");\r\n              this.open = false;\r\n              this.getList();\r\n            });\r\n          }\r\n        }\r\n      });\r\n    },\r\n    /** 删除按钮操作 */\r\n    handleDelete(row) {\r\n      const ids = [];\r\n      ids.push(row.id)\r\n      this.$confirm('是否确认删除用户编号为\"' + row.id + '\"的数据项？').then(function() {\r\n        return delUser(ids);\r\n      }).then(() => {\r\n        this.getList();\r\n        this.$message.success(\"删除成功\");\r\n      }).catch(() => {});\r\n    },\r\n    handleUploadSuccess(response, file) {\r\n      this.pictureList = [];\r\n      const avatarUrl = \"http://localhost:8080/file/download?id=\" + response.data.id\r\n      this.pictureList.push({\"url\":avatarUrl});\r\n      this.form.avatarUrl = avatarUrl\r\n      this.$message.success('文件上传成功');\r\n    },\r\n    handleUploadError(err, file) {\r\n      this.$message.error('文件上传失败');\r\n    },\r\n    handleExceed(){\r\n      this.$message.error('只能上传一个文件');\r\n    },\r\n    handleRemoveImage() {\r\n      // 清空图片 URL 和文件列表\r\n      this.form.avatarUrl = '';\r\n      this.pictureList = [];\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n::v-deep .custom-height-input .el-input__inner {  \r\n  height: 40px;  \r\n  line-height: 40px; /* 确保文本垂直居中 */  \r\n  box-sizing: border-box;\r\n  border: 1px solid;\r\n  margin-top: -10px;\r\n} \r\n</style>"]}]}