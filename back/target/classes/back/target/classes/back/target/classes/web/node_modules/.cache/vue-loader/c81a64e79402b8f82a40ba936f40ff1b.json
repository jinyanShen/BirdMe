{"remainingRequest":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\code\\BirdME\\web\\src\\views\\identification\\index.vue?vue&type=style&index=0&id=59ac5eea&lang=scss&scoped=true","dependencies":[{"path":"D:\\code\\BirdME\\web\\src\\views\\identification\\index.vue","mtime":1773318976443},{"path":"D:\\code\\BirdME\\web\\node_modules\\css-loader\\dist\\cjs.js","mtime":1773241105476},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1773241109582},{"path":"D:\\code\\BirdME\\web\\node_modules\\postcss-loader\\src\\index.js","mtime":1773241107090},{"path":"D:\\code\\BirdME\\web\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1773241104514},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js","mtime":1773241108107}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA6NA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/identification","sourcesContent":["<template>\r\n  <div class=\"identification-page\">\r\n    <div class=\"container\">\r\n      <div class=\"row\">\r\n        <div class=\"col-12\">\r\n          <div class=\"section-heading\">\r\n            <h2>鸟类智能识别</h2>\r\n            <p>上传鸟类图片，AI智能识别物种信息</p>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"row\">\r\n        <div class=\"col-lg-6\">\r\n          <div class=\"upload-card card\">\r\n            <div class=\"card-header\">\r\n              <h3>上传图片</h3>\r\n            </div>\r\n            <div class=\"card-body\">\r\n              <div class=\"upload-area\" :class=\"{ 'drag-over': isDragOver }\" \r\n                   @dragover.prevent=\"isDragOver = true\" \r\n                   @dragleave.prevent=\"isDragOver = false\"\r\n                   @drop.prevent=\"handleDrop\">\r\n                <div v-if=\"!imageSrc\" class=\"upload-placeholder\">\r\n                  <i class=\"upload-icon\">📷</i>\r\n                  <p>拖拽图片到此处或点击上传</p>\r\n                  <input type=\"file\" @change=\"handleImageUpload\" accept=\"image/*\" ref=\"fileInput\" style=\"display: none;\">\r\n                  <button class=\"main-button\" @click=\"$refs.fileInput.click()\">选择图片</button>\r\n                </div>\r\n                <div v-else class=\"image-preview\">\r\n                  <img :src=\"imageSrc\" alt=\"Uploaded Image\">\r\n                  <button class=\"remove-btn\" @click=\"removeImage\">\r\n                    <i class=\"remove-icon\">×</i>\r\n                  </button>\r\n                </div>\r\n              </div>\r\n\r\n              <div v-if=\"imageSrc\" class=\"action-buttons\">\r\n                <button class=\"main-button\" @click=\"identifyImage\" :disabled=\"loading\">\r\n                  <span v-if=\"loading\" class=\"spinner\"></span>\r\n                  <span v-else>开始识别</span>\r\n                </button>\r\n                <button class=\"border-button\" @click=\"removeImage\">重新上传</button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"col-lg-6\">\r\n          <div class=\"result-card card\" :class=\"{ 'has-result': form.name }\">\r\n            <div class=\"card-header\">\r\n              <h3>识别结果</h3>\r\n            </div>\r\n            <div class=\"card-body\">\r\n              <div v-if=\"loading\" class=\"loading-state\">\r\n                <div class=\"spinner large\"></div>\r\n                <p>正在识别中，请稍候...</p>\r\n              </div>\r\n\r\n              <div v-else-if=\"form.name\" class=\"result-content\">\r\n                <div class=\"bird-name\">\r\n                  <h2>{{ form.name }}</h2>\r\n                  <span class=\"confidence-badge\">置信度: {{ form.score ? (form.score * 100).toFixed(2) + '%' : '未知' }}</span>\r\n                </div>\r\n\r\n                <div class=\"bird-description\">\r\n                  <h4>物种介绍</h4>\r\n                  <p>{{ form.description || '暂无详细介绍' }}</p>\r\n                </div>\r\n\r\n                <div v-if=\"form.baike_url\" class=\"more-info\">\r\n                  <a :href=\"form.baike_url\" target=\"_blank\" class=\"text-button\">\r\n                    查看更多百科信息 <i>→</i>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n\r\n              <div v-else class=\"empty-state\">\r\n                <i class=\"empty-icon\">🐦</i>\r\n                <p>上传图片后显示识别结果</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n\r\n      <div class=\"row mt-4\">\r\n        <div class=\"col-12\">\r\n          <div class=\"info-cards\">\r\n            <div class=\"info-item\">\r\n              <div class=\"info-icon\">\r\n                <i>🎯</i>\r\n              </div>\r\n              <div class=\"info-content\">\r\n                <h4>高精度识别</h4>\r\n                <p>基于深度学习算法，识别准确率高达95%以上</p>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"info-item\">\r\n              <div class=\"info-icon\">\r\n                <i>⚡</i>\r\n              </div>\r\n              <div class=\"info-content\">\r\n                <h4>快速响应</h4>\r\n                <p>秒级识别速度，即时获取结果</p>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"info-item\">\r\n              <div class=\"info-icon\">\r\n                <i>📚</i>\r\n              </div>\r\n              <div class=\"info-content\">\r\n                <h4>丰富知识</h4>\r\n                <p>提供详细的物种介绍和百科链接</p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      imageSrc: '',\r\n      form: {},\r\n      loading: false,\r\n      isDragOver: false\r\n    }\r\n  },\r\n  methods: {\r\n    handleImageUpload(event) {\r\n      const file = event.target.files[0];\r\n      if (file) {\r\n        this.processFile(file);\r\n      }\r\n    },\r\n\r\n    handleDrop(event) {\r\n      this.isDragOver = false;\r\n      const file = event.dataTransfer.files[0];\r\n      if (file && file.type.startsWith('image/')) {\r\n        this.processFile(file);\r\n      } else {\r\n        this.$message.error('请上传图片文件');\r\n      }\r\n    },\r\n\r\n    processFile(file) {\r\n      const reader = new FileReader();\r\n      reader.onloadend = () => {\r\n        this.imageSrc = reader.result;\r\n      };\r\n      reader.readAsDataURL(file);\r\n    },\r\n\r\n    removeImage() {\r\n      this.imageSrc = '';\r\n      this.form = {};\r\n    },\r\n\r\n    identifyImage() {\r\n      if (!this.imageSrc) {\r\n        this.$message.error('请先上传图片');\r\n        return;\r\n      }\r\n\r\n      this.loading = true;\r\n      const formData = new FormData();\r\n      \r\n      this.imageSrc = this.imageSrc.split(',')[1];\r\n      const byteCharacters = atob(this.imageSrc);\r\n      const byteNumbers = new Array(byteCharacters.length);\r\n      for (let i = 0; i < byteCharacters.length; i++) {\r\n        byteNumbers[i] = byteCharacters.charCodeAt(i);\r\n      }\r\n      const byteArray = new Uint8Array(byteNumbers);\r\n      const blob = new Blob([byteArray], { type: 'image/jpeg' });\r\n      const file = new File([blob], 'image.jpg', { type: 'image/jpeg' });\r\n      \r\n      formData.append('file', file);\r\n\r\n      fetch('http://localhost:8080/file/identification', {\r\n        method: 'POST',\r\n        body: formData,\r\n      })\r\n      .then(response => response.json())\r\n      .then(data => {\r\n        if (data.code === 200) {\r\n          if (Array.isArray(data.data) && data.data.length > 0) {\r\n            this.form = {\r\n              name: data.data[0].name,\r\n              score: data.data[0].score,\r\n              description: '这是一只美丽的鸟类，具有独特的特征和习性。',\r\n              baike_url: 'https://baike.baidu.com/item/' + data.data[0].name\r\n            };\r\n          } else {\r\n            this.$message.warning('未能识别出鸟类信息');\r\n          }\r\n        } else {\r\n          this.$message.error(data.msg || '识别失败');\r\n        }\r\n      })\r\n      .catch(error => {\r\n        console.error('识别失败:', error);\r\n        this.$message.error('识别失败，请稍后重试');\r\n      })\r\n      .finally(() => {\r\n        this.loading = false;\r\n      });\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.identification-page {\r\n  padding: 40px 0;\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  min-height: calc(100vh - 200px);\r\n}\r\n\r\n.section-heading {\r\n  text-align: center;\r\n  margin-bottom: 50px;\r\n}\r\n\r\n.section-heading h2 {\r\n  color: #fff;\r\n  font-size: 36px;\r\n  margin-bottom: 15px;\r\n}\r\n\r\n.section-heading p {\r\n  color: rgba(255, 255, 255, 0.9);\r\n  font-size: 16px;\r\n}\r\n\r\n.card {\r\n  background: #fff;\r\n  border-radius: 20px;\r\n  padding: 30px;\r\n  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);\r\n  transition: all 0.3s ease;\r\n  height: 100%;\r\n}\r\n\r\n.card:hover {\r\n  transform: translateY(-5px);\r\n  box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);\r\n}\r\n\r\n.card-header {\r\n  margin-bottom: 25px;\r\n  padding-bottom: 15px;\r\n  border-bottom: 2px solid #f0f0f0;\r\n}\r\n\r\n.card-header h3 {\r\n  color: var(--primary-color);\r\n  font-size: 24px;\r\n  font-weight: 700;\r\n}\r\n\r\n.card-body {\r\n  min-height: 300px;\r\n}\r\n\r\n.upload-area {\r\n  border: 2px dashed #ddd;\r\n  border-radius: 15px;\r\n  padding: 40px 20px;\r\n  text-align: center;\r\n  transition: all 0.3s ease;\r\n  min-height: 300px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  cursor: pointer;\r\n}\r\n\r\n.upload-area:hover,\r\n.upload-area.drag-over {\r\n  border-color: var(--primary-color);\r\n  background-color: rgba(34, 179, 193, 0.05);\r\n}\r\n\r\n.upload-placeholder {\r\n  width: 100%;\r\n}\r\n\r\n.upload-icon {\r\n  font-size: 64px;\r\n  margin-bottom: 20px;\r\n  display: block;\r\n}\r\n\r\n.upload-placeholder p {\r\n  color: var(--text-light);\r\n  font-size: 16px;\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.image-preview {\r\n  position: relative;\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n}\r\n\r\n.image-preview img {\r\n  max-width: 100%;\r\n  max-height: 400px;\r\n  border-radius: 10px;\r\n  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);\r\n}\r\n\r\n.remove-btn {\r\n  position: absolute;\r\n  top: -10px;\r\n  right: -10px;\r\n  width: 35px;\r\n  height: 35px;\r\n  border-radius: 50%;\r\n  background-color: #ff4757;\r\n  color: #fff;\r\n  border: none;\r\n  cursor: pointer;\r\n  font-size: 24px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  box-shadow: 0 3px 10px rgba(255, 71, 87, 0.3);\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.remove-btn:hover {\r\n  background-color: #ff6b81;\r\n  transform: scale(1.1);\r\n}\r\n\r\n.remove-icon {\r\n  line-height: 1;\r\n}\r\n\r\n.action-buttons {\r\n  display: flex;\r\n  gap: 15px;\r\n  margin-top: 25px;\r\n  justify-content: center;\r\n}\r\n\r\n.result-card {\r\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\r\n  color: #fff;\r\n}\r\n\r\n.result-card .card-header h3 {\r\n  color: #fff;\r\n}\r\n\r\n.result-card .card-header {\r\n  border-bottom-color: rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.loading-state,\r\n.empty-state {\r\n  display: flex;\r\n  flex-direction: column;\r\n  align-items: center;\r\n  justify-content: center;\r\n  height: 300px;\r\n  text-align: center;\r\n}\r\n\r\n.spinner {\r\n  width: 20px;\r\n  height: 20px;\r\n  border: 2px solid rgba(255, 255, 255, 0.3);\r\n  border-radius: 50%;\r\n  border-top-color: #fff;\r\n  animation: spin 0.8s linear infinite;\r\n}\r\n\r\n.spinner.large {\r\n  width: 50px;\r\n  height: 50px;\r\n  border-width: 4px;\r\n}\r\n\r\n@keyframes spin {\r\n  to {\r\n    transform: rotate(360deg);\r\n  }\r\n}\r\n\r\n.loading-state p,\r\n.empty-state p {\r\n  color: rgba(255, 255, 255, 0.9);\r\n  margin-top: 20px;\r\n  font-size: 16px;\r\n}\r\n\r\n.empty-icon {\r\n  font-size: 64px;\r\n  margin-bottom: 20px;\r\n  display: block;\r\n}\r\n\r\n.result-content {\r\n  animation: fadeIn 0.5s ease;\r\n}\r\n\r\n@keyframes fadeIn {\r\n  from {\r\n    opacity: 0;\r\n    transform: translateY(10px);\r\n  }\r\n  to {\r\n    opacity: 1;\r\n    transform: translateY(0);\r\n  }\r\n}\r\n\r\n.bird-name {\r\n  text-align: center;\r\n  margin-bottom: 30px;\r\n  padding-bottom: 20px;\r\n  border-bottom: 1px solid rgba(255, 255, 255, 0.2);\r\n}\r\n\r\n.bird-name h2 {\r\n  color: #fff;\r\n  font-size: 32px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n.confidence-badge {\r\n  display: inline-block;\r\n  background-color: rgba(255, 255, 255, 0.2);\r\n  color: #fff;\r\n  padding: 5px 15px;\r\n  border-radius: 20px;\r\n  font-size: 14px;\r\n  font-weight: 500;\r\n}\r\n\r\n.bird-description {\r\n  margin-bottom: 25px;\r\n}\r\n\r\n.bird-description h4 {\r\n  color: #fff;\r\n  font-size: 18px;\r\n  margin-bottom: 15px;\r\n  font-weight: 600;\r\n}\r\n\r\n.bird-description p {\r\n  color: rgba(255, 255, 255, 0.9);\r\n  line-height: 1.8;\r\n  font-size: 15px;\r\n}\r\n\r\n.more-info {\r\n  text-align: center;\r\n  margin-top: 20px;\r\n}\r\n\r\n.more-info .text-button {\r\n  color: #fff;\r\n  font-size: 16px;\r\n  font-weight: 500;\r\n}\r\n\r\n.info-cards {\r\n  display: grid;\r\n  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n  gap: 30px;\r\n  margin-top: 40px;\r\n}\r\n\r\n.info-item {\r\n  background: rgba(255, 255, 255, 0.1);\r\n  backdrop-filter: blur(10px);\r\n  border-radius: 15px;\r\n  padding: 30px;\r\n  display: flex;\r\n  align-items: center;\r\n  gap: 20px;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n.info-item:hover {\r\n  background: rgba(255, 255, 255, 0.2);\r\n  transform: translateY(-5px);\r\n}\r\n\r\n.info-icon {\r\n  width: 60px;\r\n  height: 60px;\r\n  background: rgba(255, 255, 255, 0.2);\r\n  border-radius: 50%;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  font-size: 28px;\r\n  flex-shrink: 0;\r\n}\r\n\r\n.info-content h4 {\r\n  color: #fff;\r\n  font-size: 18px;\r\n  margin-bottom: 8px;\r\n  font-weight: 600;\r\n}\r\n\r\n.info-content p {\r\n  color: rgba(255, 255, 255, 0.8);\r\n  font-size: 14px;\r\n  margin: 0;\r\n  line-height: 1.6;\r\n}\r\n\r\n@media (max-width: 992px) {\r\n  .col-lg-6 {\r\n    flex: 0 0 100%;\r\n    max-width: 100%;\r\n    margin-bottom: 30px;\r\n  }\r\n\r\n  .info-cards {\r\n    grid-template-columns: 1fr;\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .identification-page {\r\n    padding: 20px 0;\r\n  }\r\n\r\n  .section-heading h2 {\r\n    font-size: 28px;\r\n  }\r\n\r\n  .card {\r\n    padding: 20px;\r\n  }\r\n\r\n  .card-header h3 {\r\n    font-size: 20px;\r\n  }\r\n\r\n  .action-buttons {\r\n    flex-direction: column;\r\n  }\r\n\r\n  .bird-name h2 {\r\n    font-size: 24px;\r\n  }\r\n\r\n  .info-item {\r\n    padding: 20px;\r\n  }\r\n}\r\n</style>"]}]}