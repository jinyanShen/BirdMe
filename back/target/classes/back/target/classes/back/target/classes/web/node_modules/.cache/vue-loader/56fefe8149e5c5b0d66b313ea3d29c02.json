{"remainingRequest":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!D:\\code\\BirdME\\web\\src\\views\\login\\index.vue?vue&type=style&index=0&id=37dfd6fc&lang=scss&scoped=true","dependencies":[{"path":"D:\\code\\BirdME\\web\\src\\views\\login\\index.vue","mtime":1741096720736},{"path":"D:\\code\\BirdME\\web\\node_modules\\css-loader\\dist\\cjs.js","mtime":1773241105476},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1773241109582},{"path":"D:\\code\\BirdME\\web\\node_modules\\postcss-loader\\src\\index.js","mtime":1773241107090},{"path":"D:\\code\\BirdME\\web\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1773241104514},{"path":"D:\\code\\BirdME\\web\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1773241104530},{"path":"D:\\code\\BirdME\\web\\node_modules\\vue-loader\\lib\\index.js","mtime":1773241108107}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAkLA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/login","sourcesContent":["<template>\r\n  <div class=\"login-container\">\r\n    <el-row>\r\n      <el-col>\r\n        <el-form  style=\"position: relative;left: -375px;\" ref=\"loginForm\" :model=\"loginForm\" :rules=\"loginRules\" class=\"login-form\" autocomplete=\"on\" label-position=\"left\">\r\n          <div class=\"title-container\">\r\n            <span class=\"title\">在线问诊系统</span>\r\n          </div>\r\n          <el-form-item prop=\"username\" style=\"margin-top: 20px;\">\r\n            <span style=\"margin-left: 110px;\">账号</span>\r\n            <el-input\r\n              ref=\"username\"\r\n              v-model=\"loginForm.username\"\r\n              placeholder=\"输入账号\"\r\n              name=\"username\"\r\n              type=\"text\"\r\n              clearable\r\n              style=\"width: 180px;margin-left: 10px;\"\r\n            />\r\n          </el-form-item>\r\n          <el-form-item prop=\"password\">\r\n            <span style=\"margin-left: 110px;\">密码</span>\r\n            <el-input\r\n              ref=\"password\"\r\n              v-model=\"loginForm.password\"\r\n              placeholder=\"输入密码\"\r\n              name=\"password\"\r\n              type=\"password\"\r\n              style=\"width: 180px;margin-left: 10px;\"\r\n              clearable\r\n            />\r\n          </el-form-item>\r\n          <el-button :loading=\"loading\" style=\"margin-left: 150px;\" type=\"primary\" class=\"login-btn\" @click.native.prevent=\"handleLogin\">\r\n            <span>登录</span>\r\n          </el-button>\r\n          <el-button class=\"login-btn\" style=\"background-color: white;\" @click.native.prevent=\"register\">\r\n            <span>注册</span>\r\n          </el-button>\r\n        </el-form>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <el-dialog title=\"注册\" :visible.sync=\"open\" width=\"600px\" append-to-body>\r\n      <el-form ref=\"form\" :model=\"form\" label-width=\"80px\">\r\n        <el-row>\r\n          <el-form-item label=\"账号\" prop=\"username\">\r\n            <el-input v-model=\"form.username\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"密码\" prop=\"password\">\r\n            <el-input v-model=\"form.password\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"姓名\" prop=\"name\">\r\n            <el-input v-model=\"form.name\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"年龄\" prop=\"age\">\r\n            <el-input v-model=\"form.age\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"联系方式\" prop=\"phone\">\r\n            <el-input v-model=\"form.phone\" />\r\n          </el-form-item>\r\n        </el-row>\r\n        <el-row>\r\n          <el-form-item label=\"用户头像\" prop=\"avatarUrl\">\r\n            <el-upload\r\n            drag\r\n            action=\"http://localhost:8080/file/upload\"\r\n            :on-success=\"handleUploadSuccess\"\r\n            :on-error=\"handleUploadError\"\r\n            list-type=\"picture\"\r\n            :limit=\"1\"\r\n            :file-list=\"pictureList\"\r\n            :on-exceed=\"handleExceed\"\r\n            accept=\".png, .jpg, .jpeg\"\r\n          >\r\n            <i class=\"el-icon-upload\"></i>\r\n            <div class=\"el-upload__text\">拖拽文件到此处上传</div>\r\n          </el-upload>\r\n          </el-form-item>\r\n        </el-row>\r\n      </el-form>\r\n      <div slot=\"footer\" class=\"dialog-footer\">\r\n        <el-button type=\"primary\" @click=\"doRegister\">确 定</el-button>\r\n        <el-button @click=\"cancel\">取 消</el-button>\r\n      </div>\r\n    </el-dialog>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport {login, register} from '@/api/login'\r\nexport default {\r\n  name: 'Login',\r\n  data() {\r\n    return {\r\n      loginForm: {\r\n        username: '',\r\n        password: '',\r\n      },\r\n      loginRules: {\r\n      },\r\n      loading: false,\r\n      // 是否显示弹出层\r\n      open: false,\r\n      // 表单参数\r\n      form: {},\r\n      pictureList: []\r\n    }\r\n  },\r\n  methods: {\r\n    handleLogin() {\r\n      this.$refs.loginForm.validate(valid => {\r\n        if (valid) {\r\n          this.loading = true\r\n          login(this.loginForm.username, this.loginForm.password)\r\n            .then(res => {\r\n              if(res.code === 200){\r\n                sessionStorage.setItem('id', res.data.id)\r\n                sessionStorage.setItem('username', res.data.username)\r\n                sessionStorage.setItem('password', res.data.password)\r\n                sessionStorage.setItem('name', res.data.name)\r\n                sessionStorage.setItem('age', res.data.age)\r\n                sessionStorage.setItem('phone', res.data.phone)\r\n                sessionStorage.setItem('avatarUrl', res.data.avatarUrl)\r\n                sessionStorage.setItem('role', res.data.role)\r\n                this.$message.success(\"登录成功\")\r\n                this.$router.push({ path: '/' })\r\n              }else{\r\n                this.loading = false\r\n                this.$message.error(res.msg)\r\n              }\r\n            })\r\n          .catch(() => {\r\n            this.loading = false\r\n          })\r\n        } else {\r\n          return false\r\n        }\r\n      })\r\n    },\r\n    cancel(){\r\n      this.open = false\r\n    },\r\n    register(){\r\n      this.open = true\r\n      this.form = {}\r\n      this.pictureList = []\r\n    },\r\n    doRegister(){\r\n      register(this.form).then(res=>{\r\n        this.open = false\r\n        this.$message.success(\"注册成功\")\r\n      })\r\n    },\r\n    handleUploadSuccess(response, file) {\r\n      this.form.avatarUrl = \"http://localhost:8080/file/download?id=\" + response.data.id\r\n      this.form.pictureList.push(response.data);\r\n      this.$message.success('文件上传成功');\r\n    },\r\n    handleUploadError(err, file) {\r\n      this.$message.error('文件上传失败');\r\n    },\r\n    handleExceed(){\r\n      this.$message.error('只能上传一个文件');\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n\r\n.login-container {\r\n  height: 100%;\r\n  width: 100%;\r\n  background: url(~@/assets/images/bg.jpg) no-repeat;\r\n  background-size: cover;\r\n\r\n  .login-form {\r\n    padding: 30px;\r\n    background: rgba(82, 132, 154, 0.65);\r\n    position: relative;\r\n    width: 500px;\r\n    max-width: 100%;\r\n    height: 280px;\r\n    margin: 11% 0px 0px 59%;\r\n    overflow: hidden;\r\n    border-radius: 5px;\r\n  }\r\n\r\n  .title-container {\r\n    position: relative;\r\n    margin-top: 5px;\r\n    .title {\r\n      font-size: 36px;\r\n      color: #000000;\r\n      margin-left: 100px;\r\n    }\r\n  }\r\n  .login-btn {\r\n    height: 45px;\r\n    width: 80px;\r\n    font-size: 16px;\r\n    margin: 5px 15px 10px 0px;\r\n  }\r\n}\r\n</style>\r\n"]}]}