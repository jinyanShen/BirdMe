;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/center","sourcesContent":["<template>\n  <div class=\"center-page\">\n    <div class=\"container\">\n      <div class=\"row\">\n        <div class=\"col-12\">\n          <div class=\"section-heading\">\n            <h2>个人中心</h2>\n            <p>管理您的个人信息和账户设置</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"col-lg-4\">\n          <div class=\"profile-card card\">\n            <div class=\"profile-header\">\n              <div class=\"avatar-wrapper\">\n                <img :src=\"form.avatarUrl || defaultAvatar\" alt=\"User Avatar\" class=\"avatar\">\n                <div class=\"avatar-overlay\">\n                  <i>📷</i>\n                </div>\n              </div>\n              <h3>{{ form.name || '未设置' }}</h3>\n              <p class=\"username\">@{{ form.username || '未设置' }}</p>\n            </div>\n\n            <div class=\"profile-stats\">\n              <div class=\"stat-item\">\n                <span class=\"stat-value\">{{ form.age || '-' }}</span>\n                <span class=\"stat-label\">年龄</span>\n              </div>\n              <div class=\"stat-divider\"></div>\n              <div class=\"stat-item\">\n                <span class=\"stat-value\">{{ form.phone || '-' }}</span>\n                <span class=\"stat-label\">联系方式</span>\n              </div>\n            </div>\n\n            <div class=\"profile-actions\">\n              <button class=\"main-button w-100\" @click=\"updateProfile\">\n                <i>💾</i> 保存修改\n              </button>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"col-lg-8\">\n          <div class=\"settings-card card\">\n            <div class=\"card-header\">\n              <h3>账户设置</h3>\n            </div>\n\n            <div class=\"card-body\">\n              <div class=\"form-section\">\n                <h4>基本信息</h4>\n                <div class=\"form-grid\">\n                  <div class=\"form-group\">\n                    <label>账号</label>\n                    <input type=\"text\" v-model=\"form.username\" class=\"form-control\" placeholder=\"请输入账号\">\n                  </div>\n                  <div class=\"form-group\">\n                    <label>密码</label>\n                    <input type=\"password\" v-model=\"form.password\" class=\"form-control\" placeholder=\"请输入密码\">\n                  </div>\n                  <div class=\"form-group\">\n                    <label>姓名</label>\n                    <input type=\"text\" v-model=\"form.name\" class=\"form-control\" placeholder=\"请输入姓名\">\n                  </div>\n                  <div class=\"form-group\">\n                    <label>年龄</label>\n                    <input type=\"number\" v-model=\"form.age\" class=\"form-control\" placeholder=\"请输入年龄\">\n                  </div>\n                  <div class=\"form-group full-width\">\n                    <label>联系方式</label>\n                    <input type=\"tel\" v-model=\"form.phone\" class=\"form-control\" placeholder=\"请输入联系方式\">\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"form-section\">\n                <h4>头像设置</h4>\n                <div class=\"upload-section\">\n                  <div class=\"upload-area\" :class=\"{ 'drag-over': isDragOver }\"\n                       @dragover.prevent=\"isDragOver = true\"\n                       @dragleave.prevent=\"isDragOver = false\"\n                       @drop.prevent=\"handleDrop\">\n                    <div v-if=\"!form.avatarUrl\" class=\"upload-placeholder\">\n                      <i class=\"upload-icon\">📷</i>\n                      <p>拖拽图片到此处或点击上传</p>\n                      <input type=\"file\" @change=\"handleImageUpload\" accept=\"image/*\" ref=\"fileInput\" style=\"display: none;\">\n                      <button class=\"border-button\" @click=\"$refs.fileInput.click()\">选择图片</button>\n                    </div>\n                    <div v-else class=\"image-preview\">\n                      <img :src=\"form.avatarUrl\" alt=\"Avatar\">\n                      <button class=\"remove-btn\" @click=\"removeAvatar\">\n                        <i>×</i>\n                      </button>\n                    </div>\n                  </div>\n                </div>\n              </div>\n\n              <div class=\"form-section\">\n                <h4>账户安全</h4>\n                <div class=\"security-info\">\n                  <div class=\"security-item\">\n                    <div class=\"security-icon\">\n                      <i>🔒</i>\n                    </div>\n                    <div class=\"security-content\">\n                      <h5>密码保护</h5>\n                      <p>定期更换密码以保护账户安全</p>\n                    </div>\n                    <button class=\"border-button\">修改密码</button>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { updateUser } from \"@/api/user\";\n\nexport default {\n  data() {\n    return {\n      form: {\n        id: parseInt(sessionStorage.getItem(\"id\")),\n        username: sessionStorage.getItem(\"username\"),\n        name: sessionStorage.getItem(\"name\"),\n        password: sessionStorage.getItem(\"password\"),\n        age: sessionStorage.getItem(\"age\"),\n        phone: sessionStorage.getItem(\"phone\"),\n        avatarUrl: sessionStorage.getItem(\"avatarUrl\"),\n      },\n      defaultAvatar: 'https://via.placeholder.com/150',\n      isDragOver: false\n    };\n  },\n\n  methods: {\n    handleImageUpload(event) {\n      const file = event.target.files[0];\n      if (file) {\n        this.uploadFile(file);\n      }\n    },\n\n    handleDrop(event) {\n      this.isDragOver = false;\n      const file = event.dataTransfer.files[0];\n      if (file && file.type.startsWith('image/')) {\n        this.uploadFile(file);\n      } else {\n        this.$message.error('请上传图片文件');\n      }\n    },\n\n    uploadFile(file) {\n      const formData = new FormData();\n      formData.append('file', file);\n\n      fetch('http://localhost:8080/file/upload', {\n        method: 'POST',\n        body: formData,\n      })\n      .then(response => response.json())\n      .then(data => {\n        if (data.code === 200) {\n          this.form.avatarUrl = \"http://localhost:8080/file/download?id=\" + data.data.id;\n          this.$message.success('头像上传成功');\n        } else {\n          this.$message.error(data.msg || '上传失败');\n        }\n      })\n      .catch(error => {\n        this.$message.error('上传失败，请稍后重试');\n      });\n    },\n\n    removeAvatar() {\n      this.form.avatarUrl = '';\n    },\n\n    updateProfile() {\n      if (!this.form.username || !this.form.password) {\n        this.$message.error('账号和密码不能为空');\n        return;\n      }\n\n      updateUser(this.form).then(res => {\n        if (res.code === 200) {\n          sessionStorage.setItem(\"id\", this.form.id);\n          sessionStorage.setItem(\"username\", this.form.username);\n          sessionStorage.setItem(\"password\", this.form.password);\n          sessionStorage.setItem(\"name\", this.form.name);\n          sessionStorage.setItem(\"age\", this.form.age);\n          sessionStorage.setItem(\"phone\", this.form.phone);\n          sessionStorage.setItem(\"avatarUrl\", this.form.avatarUrl);\n          this.$message.success(\"更新成功\");\n        } else {\n          this.$message.error(res.msg || '更新失败');\n        }\n      }).catch(error => {\n        this.$message.error('更新失败，请稍后重试');\n      });\n    }\n  }\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.center-page {\n  padding: 40px 0;\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  min-height: calc(100vh - 200px);\n}\n\n.section-heading {\n  text-align: center;\n  margin-bottom: 50px;\n}\n\n.section-heading h2 {\n  color: #fff;\n  font-size: 36px;\n  margin-bottom: 15px;\n}\n\n.section-heading p {\n  color: rgba(255, 255, 255, 0.9);\n  font-size: 16px;\n}\n\n.card {\n  background: #fff;\n  border-radius: 20px;\n  padding: 30px;\n  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);\n  transition: all 0.3s ease;\n  height: 100%;\n}\n\n.card:hover {\n  transform: translateY(-5px);\n  box-shadow: 0 15px 50px rgba(0, 0, 0, 0.15);\n}\n\n.card-header {\n  margin-bottom: 30px;\n  padding-bottom: 20px;\n  border-bottom: 2px solid #f0f0f0;\n}\n\n.card-header h3 {\n  color: var(--primary-color);\n  font-size: 24px;\n  font-weight: 700;\n}\n\n.card-body {\n  padding: 0;\n}\n\n.profile-card {\n  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n  color: #fff;\n}\n\n.profile-header {\n  text-align: center;\n  margin-bottom: 30px;\n}\n\n.avatar-wrapper {\n  position: relative;\n  width: 120px;\n  height: 120px;\n  margin: 0 auto 20px;\n}\n\n.avatar {\n  width: 100%;\n  height: 100%;\n  border-radius: 50%;\n  object-fit: cover;\n  border: 4px solid rgba(255, 255, 255, 0.3);\n  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);\n}\n\n.avatar-overlay {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  border-radius: 50%;\n  background: rgba(0, 0, 0, 0.5);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  opacity: 0;\n  transition: opacity 0.3s ease;\n  cursor: pointer;\n}\n\n.avatar-wrapper:hover .avatar-overlay {\n  opacity: 1;\n}\n\n.avatar-overlay i {\n  font-size: 32px;\n  color: #fff;\n}\n\n.profile-header h3 {\n  color: #fff;\n  font-size: 24px;\n  margin-bottom: 8px;\n  font-weight: 700;\n}\n\n.profile-header .username {\n  color: rgba(255, 255, 255, 0.8);\n  font-size: 14px;\n  margin: 0;\n}\n\n.profile-stats {\n  display: flex;\n  align-items: center;\n  justify-content: space-around;\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 15px;\n  padding: 20px;\n  margin-bottom: 30px;\n}\n\n.stat-item {\n  text-align: center;\n}\n\n.stat-value {\n  display: block;\n  font-size: 24px;\n  font-weight: 700;\n  color: #fff;\n  margin-bottom: 5px;\n}\n\n.stat-label {\n  display: block;\n  font-size: 12px;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.stat-divider {\n  width: 1px;\n  height: 40px;\n  background: rgba(255, 255, 255, 0.2);\n}\n\n.profile-actions {\n  display: flex;\n  gap: 15px;\n}\n\n.form-section {\n  margin-bottom: 40px;\n}\n\n.form-section:last-child {\n  margin-bottom: 0;\n}\n\n.form-section h4 {\n  color: var(--text-color);\n  font-size: 18px;\n  margin-bottom: 20px;\n  font-weight: 600;\n  padding-bottom: 10px;\n  border-bottom: 2px solid #f0f0f0;\n}\n\n.form-grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 20px;\n}\n\n.form-group {\n  margin-bottom: 20px;\n}\n\n.form-group.full-width {\n  grid-column: 1 / -1;\n}\n\n.form-group label {\n  display: block;\n  margin-bottom: 8px;\n  font-weight: 500;\n  color: var(--text-color);\n  font-size: 14px;\n}\n\n.form-control {\n  width: 100%;\n  padding: 12px 20px;\n  border: 1px solid #ddd;\n  border-radius: 10px;\n  font-size: 14px;\n  font-family: 'Poppins', sans-serif;\n  transition: all 0.3s;\n}\n\n.form-control:focus {\n  outline: none;\n  border-color: var(--primary-color);\n  box-shadow: 0 0 0 3px rgba(34, 179, 193, 0.1);\n}\n\n.upload-area {\n  border: 2px dashed #ddd;\n  border-radius: 15px;\n  padding: 40px 20px;\n  text-align: center;\n  transition: all 0.3s ease;\n  min-height: 200px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  cursor: pointer;\n}\n\n.upload-area:hover,\n.upload-area.drag-over {\n  border-color: var(--primary-color);\n  background-color: rgba(34, 179, 193, 0.05);\n}\n\n.upload-placeholder {\n  width: 100%;\n}\n\n.upload-icon {\n  font-size: 48px;\n  margin-bottom: 15px;\n  display: block;\n}\n\n.upload-placeholder p {\n  color: var(--text-light);\n  font-size: 14px;\n  margin-bottom: 20px;\n}\n\n.image-preview {\n  position: relative;\n  width: 100%;\n  height: 100%;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.image-preview img {\n  max-width: 200px;\n  max-height: 200px;\n  border-radius: 10px;\n  box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);\n}\n\n.remove-btn {\n  position: absolute;\n  top: -10px;\n  right: -10px;\n  width: 30px;\n  height: 30px;\n  border-radius: 50%;\n  background-color: #ff4757;\n  color: #fff;\n  border: none;\n  cursor: pointer;\n  font-size: 20px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 3px 10px rgba(255, 71, 87, 0.3);\n  transition: all 0.3s ease;\n}\n\n.remove-btn:hover {\n  background-color: #ff6b81;\n  transform: scale(1.1);\n}\n\n.security-info {\n  display: flex;\n  flex-direction: column;\n  gap: 15px;\n}\n\n.security-item {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n  padding: 20px;\n  background: #f8f9fa;\n  border-radius: 10px;\n  transition: all 0.3s ease;\n}\n\n.security-item:hover {\n  background: #f0f0f0;\n  transform: translateX(5px);\n}\n\n.security-icon {\n  width: 50px;\n  height: 50px;\n  background: var(--primary-color);\n  border-radius: 10px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 24px;\n  flex-shrink: 0;\n}\n\n.security-content {\n  flex: 1;\n}\n\n.security-content h5 {\n  color: var(--text-color);\n  font-size: 16px;\n  margin-bottom: 5px;\n  font-weight: 600;\n}\n\n.security-content p {\n  color: var(--text-light);\n  font-size: 14px;\n  margin: 0;\n}\n\n@media (max-width: 992px) {\n  .col-lg-4,\n  .col-lg-8 {\n    flex: 0 0 100%;\n    max-width: 100%;\n    margin-bottom: 30px;\n  }\n\n  .form-grid {\n    grid-template-columns: 1fr;\n  }\n}\n\n@media (max-width: 768px) {\n  .center-page {\n    padding: 20px 0;\n  }\n\n  .section-heading h2 {\n    font-size: 28px;\n  }\n\n  .card {\n    padding: 20px;\n  }\n\n  .card-header h3 {\n    font-size: 20px;\n  }\n\n  .profile-stats {\n    flex-direction: column;\n    gap: 20px;\n  }\n\n  .stat-divider {\n    width: 100%;\n    height: 1px;\n  }\n\n  .security-item {\n    flex-direction: column;\n    text-align: center;\n  }\n\n  .security-item button {\n    width: 100%;\n  }\n}\n</style>\n"]}]}