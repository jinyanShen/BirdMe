edia (max-width: 1024px) {\n  .migration-container {\n    flex-direction: column;\n    min-height: 800px;\n  }\n\n  .sidebar {\n    width: 100%;\n    max-height: 300px;\n  }\n\n  .map-container {\n    height: 500px;\n  }\n}\n\n@media (max-width: 768px) {\n  .migration-container {\n    min-height: 700px;\n  }\n\n  .sidebar {\n    max-height: 250px;\n  }\n\n  .map-container {\n    height: 400px;\n  }\n}\n\n@media (max-width: 480px) {\n  .migration-container {\n    min-height: 600px;\n  }\n\n  .sidebar {\n    max-height: 200px;\n  }\n\n  .map-container {\n    height: 300px;\n  }\n}\n</style>\n"]}]}